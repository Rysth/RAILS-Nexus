{
    "cron": [
        {
            "command": "bundle exec rails runner 'DailyCleanupJob.perform_now'",
            "schedule": "0 0 * * *"
        },
        {
            "command": "bundle exec rails runner 'HourlyUpdateJob.perform_now'",
            "schedule": "0 * * * *"
        },
        {
            "command": "bundle exec rails runner 'WeeklyReportJob.perform_now'",
            "schedule": "0 0 * * 0"
        },
        {
            "command": "bundle exec rake db:backup",
            "schedule": "0 4 * * *"
        }
    ]
}