<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
      .btn-primary {
        background-color: #3b82f6;
        color: white;
        padding: 12px 24px;
        border-radius: 6px;
        text-decoration: none;
        display: inline-block;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 24px;
      }
    </style>
  </head>
  <body class="bg-gray-100">
    <div class="container">
      <div class="bg-white p-8 rounded-lg shadow-md">
        <h2 class="text-2xl font-bold text-gray-800 mb-4">¡Bienvenido <%= @email %>!</h2>
        <p class="text-gray-600 mb-6">Puede confirmar su cuenta de correo electrónico a través del siguiente enlace:</p>
        <div class="text-center mb-6">
          <%= link_to 'Confirmar mi cuenta',
        "#{ENV['FRONTEND_URL']}/identity/email_verification?token=#{@token}",
        target: "_blank",
        rel: "noopener noreferrer",
        class: "btn-primary" %>
        </div>
        <p class="text-sm text-gray-500">Si no solicitó esto, por favor ignore este correo electrónico.</p>
      </div>
    </div>
  </body>
</html>
