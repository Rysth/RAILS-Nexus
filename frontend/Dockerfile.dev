# node:22-alpine ships Node >= 22.12.0, which satisfies oxlint's requirement.
# Bun is installed on top so bunx / bun run commands still work.
FROM node:22-alpine

# Install bun
RUN npm install -g bun

WORKDIR /app

COPY package*.json ./
RUN bun install

COPY . .

EXPOSE 5173

CMD ["bun", "run", "dev"]